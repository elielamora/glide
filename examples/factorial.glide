; Factorial example demonstrating loop/recur (tail-recursive loop)
; Run with: glide run examples/factorial.glide

fn factorial (n int) int
    loop (current n acc 1)
        if (<= current 1)
            acc
            recur (- current 1) (* acc current)

fn main ()
    for i in 1..=10
        let result (factorial i)
        fmt.Printf "%d! = %d\n" i result
